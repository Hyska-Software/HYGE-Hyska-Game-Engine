# =============================================================================
# Hyge Engine — .gitignore
# =============================================================================

# -------------------------------------------------------------------
# Rust / Cargo
# -------------------------------------------------------------------
# Build artifacts
/target/
**/target/
**/Cargo.lock.bak

# Cargo registry / cache (never commit)
/.cargo/

# Generated files by cargo build / test
**/*.pdb
**/*.dSYM/
**/*.dSYM/**
*.rlib
*.so
*.dylib
*.dll
*.exe
*.pdb
*.exp
*.lib
*.obj
*.o
*.a
*.pdb
*.idb
*.ilk

# Backups from formatters / editors
*.rs.bk
*.swp
*.swo

# -------------------------------------------------------------------
# Engine build outputs (BLAKE3 content-addressed cache)
# -------------------------------------------------------------------
# Importer output and runtime asset cache
/assets/cache/
/assets/cook/
/.assets/
/cache/
/build/
/dist/

# SQLite asset database (generated by importer / runtime)
/.hyge.db
/hyge.db
*.db
*.db-journal
*.db-shm
*.db-wal

# Hot-reload state files
/.hot-reload-state
/.reload-queue

# GPU shader cache (driver-level)
**/.cache/
**/shadercache/

# -------------------------------------------------------------------
# Profiling / tracing
# -------------------------------------------------------------------
# Tracy captures
*.tracy
/tracy-capture/
/tracy-output/

# RenderDoc / PIX captures
*.rdc
*.rdcapture
*.pix2

# GPU profiler dumps
*.gpu-profile
*.nvprof
*.nsight-rep

# -------------------------------------------------------------------
# Editor user data
# -------------------------------------------------------------------
# Docking layout and editor preferences
/user_data/
/.editor/
/.editor_state.json
/editor_layout.json

# Editor preview / thumbnails cache
/.preview-cache/
/.thumbnails/

# Undo / redo persistence
/.undo-history/
/.undo-*.bin

# Saved scenes (in-progress editor work, not source-of-truth)
/scenes/unsaved/
/scenes/.scratch/

# -------------------------------------------------------------------
# Local environment / secrets
# -------------------------------------------------------------------
# .env files
.env
.env.*
!.env.example

# API keys, tokens, certificates
**/*.pem
**/*.key
**/*.crt
**/secrets/
/secrets.yaml
/secrets.toml

# Local config overrides
/hyge.local.toml
/local.toml
/config.local.*

# -------------------------------------------------------------------
# Logs
# -------------------------------------------------------------------
*.log
*.log.*
/logs/
/hyge.log
/hyge-sandbox.log
/benchmark-results/

# -------------------------------------------------------------------
# Generated documentation
# -------------------------------------------------------------------
# rustdoc output
/doc/
/docs/api/
/target/doc/
**/target/doc/

# mdbook build output
/book/
/docs/mdbook/book/

# Coverage reports
/coverage/
*.lcov
*.info
/tarpaulin-report.html
/grcov/
/llvm-cov/

# -------------------------------------------------------------------
# IDE / Editor
# -------------------------------------------------------------------
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# IntelliJ / CLion / RustRover
.idea/
*.iml
*.iws
*.ipr
/out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.viminfo
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Helix
.helix/

# Zed
.zed/

# -------------------------------------------------------------------
# OS-specific
# -------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems
/Volumes/
/.AppleDouble
/Library/Caches/
/private/

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.url
[Aa][Tt][Tt][Dd][Bb]~
System Volume Information/

# Linux
*~
.directory
.Trash-*
.nfs*

# -------------------------------------------------------------------
# Build / CI artifacts
# -------------------------------------------------------------------
# GitHub Actions runner
.ansible/
.runner/

# Docker (if added later)
.docker/
docker-compose.override.yml
.dockerignore.bak

# Release artifacts (built by CI, not committed)
/release/
/artifacts/
/target/release/
/target/debug/

# Benchmark output
/criterion/
/benches/results/
/perf/measurements/

# -------------------------------------------------------------------
# Test artifacts
# -------------------------------------------------------------------
# Snapshot test goldens are committed; only ignore diffs
*.snap.new
*.snap.actual

# Headless test outputs
/test-output/
/test-results/
/test-screenshots/

# Proptest regression cases
proptest-regressions/
proptest-regressions-*.txt

# Fuzz corpus (committed only at meaningful checkpoints)
fuzz/corpus/
fuzz/artifacts/

# Miri output
miri-output/
miri_logs/

# Coverage / test reports
tarpaulin-report.html
grcov-*.lcov

# -------------------------------------------------------------------
# Vulkan / GPU / wgpu runtime
# -------------------------------------------------------------------
# Vulkan validation layer output
VK_LAYER_*.log
vulkaninfo-output.txt
*.vkout

# DXVK / Proton caches (in case anyone runs on Linux)
/.dxvk-cache/
/.proton-cache/

# -------------------------------------------------------------------
# Rust toolchain / rustup
# -------------------------------------------------------------------
# Don't commit rustup home
.rustup/
# Don't commit cargo registry
.cargo/registry/
.cargo/git/

# -------------------------------------------------------------------
# Hyge-specific excludes for source-controlled patterns
# -------------------------------------------------------------------
# Allow asset source files (committed), but not generated cache
!/assets/
!/assets/**

# Allow test references (golden images)
!/assets/tests/
!/assets/tests/**

# Allow benchmark sources
!/benches/
!/benches/**
!/perf/
!/perf/baseline.json
!/perf/*.json
!/perf/*.toml

# Allow CI configs
!/.github/
!/.github/**
!/.github/workflows/
!/.github/workflows/**

# Allow docs
!/docs/
!/docs/**
!/.kilo/
!/.kilo/**
.kilo
# -------------------------------------------------------------------
# Notes for contributors
# -------------------------------------------------------------------
# When adding new patterns, prefer uncommenting an existing category
# rather than appending to the end. This keeps the file diffable.
#
# If you need to force-add an ignored file:
#   git add -f <path>
#
# If you need to check why a file is ignored:
#   git check-ignore -v <path>


.hermes/

