{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyge.dev/schemas/editor-protocol-v1.json",
  "title": "Hyge Editor IPC Envelope",
  "description": "Version 1 length-prefixed JSON control protocol between hyge-editor and the PySide6/QML frontend.",
  "type": "object",
  "required": ["protocol_version", "message_id", "message_type", "payload"],
  "additionalProperties": false,
  "properties": {
    "protocol_version": { "type": "integer", "minimum": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "message_type": {
      "type": "string",
      "enum": [
        "hello", "hello_ack", "open_project", "open_scene", "save_scene",
        "select_entities", "edit_component", "add_component", "remove_component",
        "reparent_entity", "duplicate_entity", "destroy_entity", "instantiate_prefab",
        "undo", "redo", "set_editor_camera", "set_viewport_size", "request_asset_preview",
        "world_snapshot", "selection_changed", "component_changed", "asset_changed",
        "scene_reloaded", "console_line", "profiler_sample", "viewport_frame_available",
        "command_completed", "engine_error", "server_shutdown", "lifecycle_status"
      ]
    },
    "payload": { "type": "object" },
    "error": { "$ref": "#/$defs/error" }
  },
  "allOf": [
    {
      "if": { "properties": { "message_type": { "const": "edit_component" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/edit_component_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "add_component" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/add_component_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "remove_component" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/remove_component_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "reparent_entity" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/reparent_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "duplicate_entity" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/entity_command_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "destroy_entity" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/entity_command_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "instantiate_prefab" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/instantiate_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "enum": ["undo", "redo"] } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/history_payload" } } }
    },
    {
      "if": { "properties": { "message_type": { "const": "hello" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/hello_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "hello_ack" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/hello_ack_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "lifecycle_status" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/lifecycle_status_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "engine_error" } } },
      "then": { "required": ["error"] },
      "else": { "not": { "required": ["error"] } }
    },
    {
      "if": { "properties": { "message_type": { "const": "select_entities" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/select_entities_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "selection_changed" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/selection_changed_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "world_snapshot" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/world_snapshot_payload" }
        }
      }
    }
  ],
  "$defs": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "hello_payload": {
      "type": "object",
      "required": ["client_name", "supported_protocol_versions", "session_token"],
      "additionalProperties": false,
      "properties": {
        "client_name": { "type": "string", "minLength": 1 },
        "supported_protocol_versions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "session_id": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "session_token": { "type": "string", "minLength": 1 }
      }
    },
    "hello_ack_payload": {
      "type": "object",
      "required": ["selected_protocol_version", "session_id", "resumed", "server", "request_timeout_ms"],
      "additionalProperties": false,
      "properties": {
        "selected_protocol_version": { "type": "integer", "minimum": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "resumed": { "type": "boolean" },
        "server": { "const": "hyge-editor" },
        "request_timeout_ms": { "type": "integer", "minimum": 1 }
      }
    },
    "lifecycle_status_payload": {
      "type": "object",
      "required": ["session_id", "state", "details"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "type": "string" },
        "state": { "enum": ["loading", "ready", "degraded", "failed"] },
        "details": { "type": "object" }
      }
    },
    "select_entities_payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entities": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "shift": { "type": "boolean", "default": false },
        "scene_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "anyOf": [
        { "required": ["entities"] },
        { "required": ["scene_ids"] }
      ]
    },
    "selection_changed_payload": {
      "type": "object",
      "required": ["revision", "scene_revision", "entities"],
      "additionalProperties": false,
      "properties": {
        "revision": { "type": "integer", "minimum": 1 },
        "scene_revision": { "type": "integer", "minimum": 0 },
        "entities": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "scene_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "world_snapshot_payload": {
      "type": "object",
      "required": ["revision", "scene_revision", "hierarchy", "entities", "component_catalog", "selection", "diagnostics"],
      "additionalProperties": true,
      "properties": {
        "revision": { "type": "integer", "minimum": 1 },
        "scene_revision": { "type": "integer", "minimum": 0 },
        "hierarchy": { "type": "array" },
        "entities": { "type": "array" },
        "component_catalog": { "type": "array" },
        "selection": { "type": "array" },
        "diagnostics": { "type": "array" }
      }
    },
    "revision_payload": {
      "type": "object",
      "required": ["expected_revision"],
      "additionalProperties": true,
      "properties": { "expected_revision": { "type": "integer", "minimum": 1 } }
    },
    "entity_command_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["entity"], "properties": { "entity": { "type": "integer", "minimum": 0 } } }
      ]
    },
    "edit_component_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["entity", "type_path", "value"], "properties": {
          "entity": { "type": "integer", "minimum": 0 },
          "type_path": { "type": "string", "minLength": 1 },
          "field_path": { "type": ["string", "null"] },
          "value": {}
        } }
      ]
    },
    "add_component_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["entity", "type_path", "value"], "properties": {
          "entity": { "type": "integer", "minimum": 0 }, "type_path": { "type": "string", "minLength": 1 }, "value": {}
        } }
      ]
    },
    "remove_component_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["entity", "type_path"], "properties": {
          "entity": { "type": "integer", "minimum": 0 }, "type_path": { "type": "string", "minLength": 1 }
        } }
      ]
    },
    "reparent_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["entity"], "properties": {
          "entity": { "type": "integer", "minimum": 0 }, "new_parent": { "type": ["integer", "null"], "minimum": 0 }
        } }
      ]
    },
    "instantiate_payload": {
      "allOf": [
        { "$ref": "#/$defs/revision_payload" },
        { "required": ["prefab", "transform"], "properties": {
          "prefab": { "type": "object" }, "transform": { "type": "object" }, "parent": { "type": ["integer", "null"], "minimum": 0 }
        } }
      ]
    },
    "history_payload": {
      "allOf": [ { "$ref": "#/$defs/revision_payload" } ]
    }
  },
  "x-hyge-message-directions": {
    "requests": ["hello", "open_project", "open_scene", "save_scene", "select_entities", "edit_component", "add_component", "remove_component", "reparent_entity", "duplicate_entity", "destroy_entity", "instantiate_prefab", "undo", "redo", "set_editor_camera", "set_viewport_size", "request_asset_preview", "server_shutdown"],
    "responses": ["hello_ack", "command_completed", "engine_error"],
    "events": ["lifecycle_status", "world_snapshot", "selection_changed", "component_changed", "asset_changed", "scene_reloaded", "console_line", "profiler_sample", "viewport_frame_available"]
  }
}
