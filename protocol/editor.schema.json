{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyge.dev/schemas/editor-protocol-v1.json",
  "title": "Hyge Editor IPC Envelope",
  "description": "Version 1 length-prefixed JSON control protocol between hyge-editor and the PySide6/QML frontend.",
  "type": "object",
  "required": ["protocol_version", "message_id", "message_type", "payload"],
  "additionalProperties": false,
  "properties": {
    "protocol_version": { "type": "integer", "minimum": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "message_type": {
      "type": "string",
      "enum": [
        "hello", "hello_ack", "open_project", "open_scene", "save_scene",
        "select_entities", "edit_component", "add_component", "remove_component",
        "reparent_entity", "duplicate_entity", "destroy_entity", "instantiate_prefab",
        "undo", "redo", "set_editor_camera", "set_viewport_size", "request_asset_preview",
        "world_snapshot", "selection_changed", "component_changed", "asset_changed",
        "scene_reloaded", "console_line", "profiler_sample", "viewport_frame_available",
        "command_completed", "engine_error", "server_shutdown"
      ]
    },
    "payload": { "type": "object" },
    "error": { "$ref": "#/$defs/error" }
  },
  "allOf": [
    {
      "if": { "properties": { "message_type": { "const": "hello" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/hello_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "hello_ack" } } },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/hello_ack_payload" }
        }
      }
    },
    {
      "if": { "properties": { "message_type": { "const": "engine_error" } } },
      "then": { "required": ["error"] },
      "else": { "not": { "required": ["error"] } }
    }
  ],
  "$defs": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "hello_payload": {
      "type": "object",
      "required": ["client_name", "supported_protocol_versions", "session_token"],
      "additionalProperties": false,
      "properties": {
        "client_name": { "type": "string", "minLength": 1 },
        "supported_protocol_versions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "session_id": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "session_token": { "type": "string", "minLength": 1 }
      }
    },
    "hello_ack_payload": {
      "type": "object",
      "required": ["selected_protocol_version", "session_id", "resumed", "server", "request_timeout_ms"],
      "additionalProperties": false,
      "properties": {
        "selected_protocol_version": { "type": "integer", "minimum": 1 },
        "session_id": { "type": "string", "minLength": 1 },
        "resumed": { "type": "boolean" },
        "server": { "const": "hyge-editor" },
        "request_timeout_ms": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "x-hyge-message-directions": {
    "requests": ["hello", "open_project", "open_scene", "save_scene", "select_entities", "edit_component", "add_component", "remove_component", "reparent_entity", "duplicate_entity", "destroy_entity", "instantiate_prefab", "undo", "redo", "set_editor_camera", "set_viewport_size", "request_asset_preview", "server_shutdown"],
    "responses": ["hello_ack", "command_completed", "engine_error"],
    "events": ["world_snapshot", "selection_changed", "component_changed", "asset_changed", "scene_reloaded", "console_line", "profiler_sample", "viewport_frame_available"]
  }
}
